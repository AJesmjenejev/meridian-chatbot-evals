# Copy to .env and fill in. The invitation link looks like:
#   https://2ndround.sandb0x.run/?token=XXXX-XXXX-...
# Put the host in MERIDIAN_BASE_URL and the token value in MERIDIAN_TOKEN.
MERIDIAN_BASE_URL=https://2ndround.sandb0x.run
MERIDIAN_TOKEN=your-token-here

# Optional: if GET /api/state is unavailable on your network, capture it once
# from a browser and point the harness at the file:
#   MERIDIAN_STATE_FILE=captured_state.json
# Optional: skip TLS verification if your network's root CA isn't trusted:
#   MERIDIAN_VERIFY_SSL=false